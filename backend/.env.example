PORT=5000

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=mini_smart_ledger
DB_PORT=3306

# Auth
JWT_SECRET=SecurityStringForJWT
JWT_EXPIRES_IN=7d

# Discord notifications
DISCORD_WEBHOOK_URL=

# Large transaction alert threshold (in rupees)
LARGE_TRANSACTION_THRESHOLD=10000

# Spending lock feature
SPENDING_LOCK_COOLDOWN_MINUTES=15

# Redis (dashboard summary/charts caching — optional, degrades gracefully if unset)
REDIS_URL=redis://localhost:6379

# SMTP (used for the spending-lock lockout email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mini Smart Ledger <no-reply@ledger.local>"
